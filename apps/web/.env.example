# Supabase (EU region — Frankfurt)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL
NEXT_PUBLIC_APP_URL=https://app.stundly.de

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs (aus Stripe Dashboard)
STRIPE_PRICE_INDIVIDUAL_MONTHLY=price_...
STRIPE_PRICE_INDIVIDUAL_YEARLY=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_YEARLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_YEARLY=price_...

# Resend (https://resend.com)
RESEND_API_KEY=re_...

# Anthropic Claude (KI-Funktionen)
ANTHROPIC_API_KEY=sk-ant-...

# Support WhatsApp (international format, no + or spaces — e.g. 491701234567)
# Wenn leer, wird der WhatsApp-Button nicht angezeigt
NEXT_PUBLIC_SUPPORT_WHATSAPP=
